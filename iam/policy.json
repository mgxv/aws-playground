{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ReadAll",
      "Effect": "Allow",
      "Action": [
        "s3:Get*",
        "s3:List*",
        "s3:Describe*"
      ],
      "Resource": [
        "arn:aws:s3:::my-demo-bucket",
        "arn:aws:s3:::my-demo-bucket/*"
      ]
    }
  ]
}
