{
    "name": "aws-playground",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
        "extensions": [
            "hashicorp.terraform",
            "pulumi.pulumi-lsp-client"
        ]
        }
    }
}
